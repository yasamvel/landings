<!DOCTYPE html>
<html lang="ru" data-lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Samvel Ervandian — AI Agent Engineering</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --linkedin-blue: #0A66C2;
      --linkedin-dark: #000000e6;
      --linkedin-bg: #f3f2ef;
      --linkedin-card: #ffffff;
      --linkedin-gray: #666666;
      --linkedin-border: #e0dfdc;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, system-ui, sans-serif;
      background: var(--linkedin-bg);
      color: #191919;
      padding-top: 52px;
    }
    /* Navbar */
    .ln-navbar {
      background: var(--linkedin-blue);
      height: 52px;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1030;
      box-shadow: 0 1px 3px rgba(0,0,0,.15);
    }
    .ln-navbar .container { height: 100%; display: flex; align-items: center; justify-content: space-between; }
    .ln-logo { color: #fff; font-weight: 700; font-size: 1.25rem; letter-spacing: -.5px; display: flex; align-items: center; gap: 8px; }
    .ln-logo i { font-size: 1.5rem; }
    .ln-nav-right { display: flex; align-items: center; gap: 12px; }
    .ln-lang-btn {
      background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.3);
      color: #fff;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: .8rem;
      font-weight: 500;
      cursor: pointer;
      transition: all .2s;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .ln-lang-btn:hover { background: rgba(255,255,255,.25); }
    .ln-lang-btn .badge-lang { font-weight: 700; }
    .ln-nav-icon { color: rgba(255,255,255,.8); font-size: .9rem; cursor: pointer; padding: 6px; border-radius: 4px; transition: all .2s; display: none; }
    .ln-nav-icon:hover { background: rgba(255,255,255,.15); color: #fff; }

    /* Layout */
    .ln-layout { max-width: 1128px; margin: 24px auto; padding: 0 16px; display: grid; grid-template-columns: 320px 1fr; gap: 24px; }
    @media (max-width: 768px) { .ln-layout { grid-template-columns: 1fr; } }

    /* Sidebar Profile */
    .ln-sidebar { position: sticky; top: 80px; align-self: start; }
    .ln-profile-card {
      background: var(--linkedin-card);
      border-radius: 12px;
      border: 1px solid var(--linkedin-border);
      overflow: hidden;
      margin-bottom: 16px;
    }
    .ln-profile-banner {
      height: 56px;
      background: linear-gradient(135deg, #0A66C2, #004182);
    }
    .ln-profile-avatar {
      width: 72px; height: 72px;
      border-radius: 50%;
      border: 2px solid #fff;
      background: #0A66C2;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      font-weight: 700;
      color: #fff;
      margin: -36px auto 0 16px;
      position: relative;
      z-index: 1;
      overflow: hidden;
    }
    .ln-profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .ln-post-avatar {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: #0A66C2;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
      overflow: hidden;
    }
    .ln-post-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .ln-profile-body { padding: 12px 16px 16px; }
    .ln-profile-name { font-size: 1rem; font-weight: 700; color: #191919; margin: 0; }
    .ln-profile-title { font-size: .82rem; color: #666; margin: 2px 0 8px; line-height: 1.3; }
    .ln-profile-tagline { font-size: .78rem; color: #666; border-top: 1px solid var(--linkedin-border); padding-top: 10px; margin-top: 4px; display: flex; align-items: center; gap: 6px; }
    .ln-profile-tagline i { color: var(--linkedin-blue); }

    /* Feed */
    .ln-feed { }
    .ln-post {
      background: var(--linkedin-card);
      border-radius: 12px;
      border: 1px solid var(--linkedin-border);
      padding: 20px;
      margin-bottom: 16px;
      transition: box-shadow .15s;
    }
    .ln-post:hover { box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .ln-post-header {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 12px;
    }
    .ln-post-author { font-weight: 700; font-size: .88rem; color: #191919; margin: 0; line-height: 1.2; }
    .ln-post-meta { font-size: .75rem; color: #666; margin: 0; display: flex; align-items: center; gap: 4px; }
    .ln-post-badge { background: #e8f4fd; color: var(--linkedin-blue); font-size: .7rem; font-weight: 600; padding: 2px 8px; border-radius: 10px; margin: 6px 0 8px; display: inline-block; }
    .ln-post-content { font-size: .92rem; line-height: 1.55; color: #333; margin-bottom: 14px; }
    .ln-post-content p { margin-bottom: 8px; }
    .ln-post-content strong { font-weight: 600; color: #191919; }
    .ln-post-content ul { padding-left: 18px; margin: 6px 0 10px; }
    .ln-post-content ul li { margin-bottom: 4px; }
    .ln-post-footer {
      display: flex;
      align-items: center;
      gap: 20px;
      padding-top: 12px;
      border-top: 1px solid var(--linkedin-border);
      font-size: .8rem;
      color: #666;
    }
    .ln-post-footer i { font-size: 1.1rem; }
    .ln-post-footer span { display: flex; align-items: center; gap: 6px; cursor: pointer; padding: 4px 8px; border-radius: 4px; transition: background .15s; }
    .ln-post-footer span:hover { background: #f0f0f0; }

    /* Language visibility */
    [data-lang="ru"] .ln-en-only { display: none !important; }
    [data-lang="en"] .ln-ru-only { display: none !important; }

    .ln-section-title { font-size: 1rem; font-weight: 700; color: #191919; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid var(--linkedin-blue); display: flex; align-items: center; gap: 8px; }

    /* Empty state */
    .ln-empty { text-align: center; padding: 40px 20px; color: #666; }
    .ln-empty i { font-size: 2.5rem; color: #bbb; margin-bottom: 12px; }
    .ln-empty p { font-size: .9rem; }

    /* Utils */
    .text-linkedin { color: var(--linkedin-blue) !important; }

    /* Scroll animation */
    .ln-post { opacity: 0; transform: translateY(20px); animation: fadeUp .5s ease forwards; }
    .ln-post:nth-child(1) { animation-delay: .05s; }
    .ln-post:nth-child(2) { animation-delay: .1s; }
    .ln-post:nth-child(3) { animation-delay: .15s; }
    .ln-post:nth-child(4) { animation-delay: .2s; }
    .ln-post:nth-child(5) { animation-delay: .25s; }
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    /* Footer */
    .ln-footer { text-align: center; padding: 24px 0 40px; color: #888; font-size: .78rem; border-top: 1px solid var(--linkedin-border); margin-top: 16px; max-width: 1128px; margin-left: auto; margin-right: auto; }
  </style>
</head>
<body>

<!-- ====== NAVBAR ====== -->
<nav class="ln-navbar">
  <div class="container">
    <div class="ln-logo">
      <i class="fab fa-linkedin"></i>
      <span class="ln-ru-only">Samvel Ervandian</span>
      <span class="ln-en-only">Samvel Ervandian</span>
    </div>
    <div class="ln-nav-right">
      <button class="ln-lang-btn" onclick="toggleLang()">
        <i class="fas fa-globe"></i>
        <span class="badge-lang ln-ru-only">EN</span>
        <span class="badge-lang ln-en-only">RU</span>
      </button>
